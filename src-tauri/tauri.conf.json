{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "Mossy",
  "version": "0.1.0",
  "identifier": "com.mossy.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Mossy",
        "width": 256,
        "height": 320,
        "alwaysOnTop": true,
        "center": true,
        "hiddenTitle": true,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "fullscreen": false,
        "visibleOnAllWorkspaces": true,
        "shadow": false,
        "skipTaskbar": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null,
      "freezePrototype": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/llama-server"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
